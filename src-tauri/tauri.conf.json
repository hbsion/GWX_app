{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "微客邦·在线",
  "version": "3.0.3",
  "identifier": "com.beemin.gwx",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "https://gwk.ikn.cc"
  },
  "app": {
    "windows": [
      {
        "title": "维客邦·在线",
        "width": 1600,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg" 
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macos": {
      "entitlements": null,
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "nsis": {
        "languages": ["Chinese"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
